# MockMate environment template
# Copy to .env.local and fill real values before running locally.

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase (required for auth/data)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Upstash Redis (recommended for rate limiting/cache)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key
GEMINI_API_KEY=
GROQ_API_KEY=your-groq-api-key

# -----------------------------------------------------------------------------
# Email / notifications
# -----------------------------------------------------------------------------
RESEND_API_KEY=
FEEDBACK_EMAIL=

# -----------------------------------------------------------------------------
# Azure integrations
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-name.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_STORAGE_CONNECTION_STRING=

# -----------------------------------------------------------------------------
# Optional execution APIs
# -----------------------------------------------------------------------------
JUDGE0_API_KEY=

# -----------------------------------------------------------------------------
# Optional external quiz dataset sources
# -----------------------------------------------------------------------------
AWS_QUESTIONS_URL=
AZURE_QUESTIONS_URL=
SALESFORCE_QUESTIONS_URL=
MONGODB_QUESTIONS_URL=
PCAP_QUESTIONS_URL=
ORACLE_QUESTIONS_URL=
NEXT_PUBLIC_AZURE_FINAL_JSON_URL=

# -----------------------------------------------------------------------------
# Career Ops cron security
# -----------------------------------------------------------------------------
CRON_SCAN_SECRET=
CRON_LIVENESS_SECRET=
CRON_CAREER_OPS_SECRET=

# Optional scanner title filters (comma-separated)
SCAN_TITLE_KEYWORDS="developer,engineer,machine learning,software"
SCAN_NEGATIVE_TITLE_KEYWORDS="intern,junior"

# Optional PDF generation timeout (ms)
RESUME_PDF_TIMEOUT_MS=25000
